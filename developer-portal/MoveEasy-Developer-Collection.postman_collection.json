{\n    "info": {\n        "name": "MoveEasy Developer Collection",\n        "description": "This is a collection for the MoveEasy API with all necessary requests implemented.",\n        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"\n    },\n    "item": [\n        {\n            "name": "OAuth2 Authorization",\n            "request": {\n                "url": "{{auth_url}}/oauth2/authorize?client_id={{client_id}}&redirect_uri={{redirect_uri}}",\n                "method": "GET"\n            }\n        },\n        {\n            "name": "Token Exchange",\n            "request": {\n                "url": "{{auth_url}}/oauth2/token",\n                "method": "POST",\n                "body": {\n                    "mode": "x-www-form-urlencoded",\n                    "urlencoded": [\n                        {"key": "client_id", "value": "{{client_id}}"},\n                        {"key": "client_secret", "value": "{{client_secret}}"},\n                        {"key": "grant_type", "value": "authorization_code"},\n                        {"key": "redirect_uri", "value": "{{redirect_uri}}"},\n                        {"key": "code", "value": "{{code}}"}\n                    ]\n                }\n            }\n        },\n        {\n            "name": "Create Account",\n            "request": {\n                "url": "{{api_url}}/accounts",\n                "method": "POST",\n                "body": {\n                    "mode": "raw",\n                    "raw": "{\"name\": \"New User\", \"email\": \"user@example.com\"}"\n                }\n            }\n        },\n        {\n            "name": "Get Account",\n            "request": {\n                "url": "{{api_url}}/accounts/{{account_id}}",\n                "method": "GET"\n            }\n        },\n        {\n            "name": "List Transactions",\n            "request": {\n                "url": "{{api_url}}/transactions",\n                "method": "GET"\n            }\n        },\n        {\n            "name": "Initiate Payment",\n            "request": {\n                "url": "{{payments_url}}/payments",\n                "method": "POST",\n                "body": {\n                    "mode": "raw",\n                    "raw": "{\"amount\": 100, \"currency\": \"USD\", \"account_id\": \"{{account_id}}\"}"\n                }\n            }\n        },\n        {\n            "name": "Get Payment Status",\n            "request": {\n                "url": "{{payments_url}}/payments/{{payment_id}}",\n                "method": "GET"\n            }\n        },\n        {\n            "name": "Create Merchant",\n            "request": {\n                "url": "{{merchant_url}}/merchants",\n                "method": "POST",\n                "body": {\n                    "mode": "raw",\n                    "raw": "{\"name\": \"New Merchant\", \"email\": \"merchant@example.com\"}"\n                }\n            }\n        },\n        {\n            "name": "Get Merchant",\n            "request": {\n                "url": "{{merchant_url}}/merchants/{{merchant_id}}",\n                "method": "GET"\n            }\n        },\n        {\n            "name": "Submit KYC",\n            "request": {\n                "url": "{{kyc_url}}/kyc",\n                "method": "POST",\n                "body": {\n                    "mode": "raw",\n                    "raw": "{\"name\": \"User KYC\", \"document\": \"document_url_here\"}"\n                }\n            }\n        },\n        {\n            "name": "Get KYC Status",\n            "request": {\n                "url": "{{kyc_url}}/kyc/{{kyc_id}}",\n                "method": "GET"\n            }\n        }\n    ],\n    "variables": [\n        {\n            "key": "auth_url",\n            "value": "https://auth.sandbox.example.com"\n        },\n        {\n            "key": "api_url",\n            "value": "https://api.sandbox.example.com"\n        },\n        {\n            "key": "payments_url",\n            "value": "https://payments.sandbox.example.com"\n        },\n        {\n            "key": "merchant_url",\n            "value": "https://merchant.sandbox.example.com"\n        },\n        {\n            "key": "kyc_url",\n            "value": "https://kyc.sandbox.example.com"\n        },\n        {\n            "key": "client_id",\n            "value": "sandbox_client_id"\n        },\n        {\n            "key": "redirect_uri",\n            "value": "https://sandbox.example.com/callback"\n        },\n        {\n            "key": "access_token",\n            "value": "sandbox_access_token"\n        },\n        {\n            "key": "randomInt",\n            "value": "{{randomInt}}"\n        }\n    ]\n}